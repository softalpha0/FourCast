# BNB Chain RPC — use a private endpoint for production reliability
BSC_RPC_HTTP=https://bsc-rpc.publicnode.com
BSC_RPC_WS=wss://bsc-rpc.publicnode.com

# Premium RPC (QuickNode / NodeReal recommended for production)
# BSC_RPC_HTTP=https://YOUR_QUICKNODE_ENDPOINT
# BSC_RPC_WS=wss://YOUR_QUICKNODE_WS_ENDPOINT

# Wallet — required for live execution, leave empty for paper trading
PRIVATE_KEY=

# Paper trading mode — set to false to enable real on-chain execution
PAPER_TRADING=true

# API server port
PORT=3000

# BscScan API key (free at bscscan.com) — used for historical curve discovery
BSCSCAN_API_KEY=

# Bitquery API key (optional) — higher rate limits for curve data
BITQUERY_API_KEY=

# Position sizing
MAX_POSITION_BNB=0.05         # Max BNB per position
MAX_OPEN_POSITIONS=5          # Max concurrent positions
MIN_CURVE_SCORE=60            # Minimum score (0-100) to enter a position
MIN_GRADUATION_PROBABILITY=0.3  # Minimum graduation probability to consider

# Exit strategy
EXIT_ON_GRADUATION=true       # Auto-exit to BNB post-graduation
POST_GRAD_HOLD_MINUTES=30     # Minutes to hold post-graduation before exit if price allows
